{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mindware-lab.github.io/schemas/seo-score.schema.json",
  "title": "SeoScoreRecord",
  "type": "object",
  "required": [
    "workspace_id",
    "mission_id",
    "run_id",
    "site_id",
    "score_scope",
    "score_key",
    "pillar",
    "weighted_score",
    "remaining_opportunity"
  ],
  "properties": {
    "workspace_id": {
      "type": "string"
    },
    "mission_id": {
      "type": "string",
      "format": "uuid"
    },
    "run_id": {
      "type": "string",
      "format": "uuid"
    },
    "site_id": {
      "type": "string"
    },
    "score_scope": {
      "type": "string",
      "enum": [
        "check",
        "pillar",
        "page",
        "site"
      ]
    },
    "score_key": {
      "type": "string",
      "minLength": 2
    },
    "pillar": {
      "type": "string",
      "minLength": 2
    },
    "weighted_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "remaining_opportunity": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "negative_contribution": {
      "type": "number",
      "minimum": 0
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "additionalProperties": false
}
