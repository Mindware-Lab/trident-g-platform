{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mindware-lab.github.io/schemas/page-brief.schema.json",
  "title": "PageKeywordBrief",
  "type": "object",
  "required": [
    "page_url",
    "intent",
    "primary_keyword",
    "secondary_keywords",
    "current_title",
    "suggested_title",
    "current_description",
    "suggested_description",
    "recommended_h2s",
    "internal_link_targets",
    "notes"
  ],
  "properties": {
    "page_url": { "type": "string", "format": "uri" },
    "intent": { "type": "string", "enum": ["commercial", "informational", "navigational", "transactional"] },
    "primary_keyword": { "type": "string", "minLength": 2 },
    "secondary_keywords": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 2 }
    },
    "current_title": { "type": "string" },
    "suggested_title": { "type": "string" },
    "current_description": { "type": "string" },
    "suggested_description": { "type": "string" },
    "recommended_h2s": {
      "type": "array",
      "items": { "type": "string" }
    },
    "internal_link_targets": {
      "type": "array",
      "items": { "type": "string" }
    },
    "notes": { "type": "string" }
  },
  "additionalProperties": false
}
