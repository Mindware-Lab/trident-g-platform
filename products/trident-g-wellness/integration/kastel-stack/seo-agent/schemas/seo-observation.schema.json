{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mindware-lab.github.io/schemas/seo-observation.schema.json",
  "title": "SeoObservation",
  "type": "object",
  "required": [
    "workspace_id",
    "mission_id",
    "run_id",
    "site_id",
    "scope_type",
    "scope_key",
    "check_id",
    "observation_status",
    "raw_value",
    "normalized_score",
    "confidence",
    "evidence_refs"
  ],
  "properties": {
    "workspace_id": {
      "type": "string",
      "minLength": 2
    },
    "mission_id": {
      "type": "string",
      "format": "uuid"
    },
    "run_id": {
      "type": "string",
      "format": "uuid"
    },
    "site_id": {
      "type": "string",
      "minLength": 2
    },
    "scope_type": {
      "type": "string",
      "enum": [
        "site",
        "page",
        "query_page",
        "location",
        "citation",
        "review"
      ]
    },
    "scope_key": {
      "type": "string",
      "minLength": 2
    },
    "check_id": {
      "type": "string",
      "minLength": 3
    },
    "observation_status": {
      "type": "string",
      "enum": [
        "pass",
        "partial",
        "fail"
      ]
    },
    "raw_value": {},
    "normalized_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
