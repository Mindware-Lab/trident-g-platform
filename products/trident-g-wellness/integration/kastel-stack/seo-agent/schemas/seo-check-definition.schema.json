{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mindware-lab.github.io/schemas/seo-check-definition.schema.json",
  "title": "SeoCheckDefinition",
  "type": "object",
  "required": [
    "check_id",
    "label",
    "pillar",
    "weight",
    "scope",
    "answer_type",
    "source_method",
    "autonomy_level",
    "risk_class",
    "pass_rule",
    "evidence_required"
  ],
  "properties": {
    "check_id": {
      "type": "string",
      "minLength": 3
    },
    "label": {
      "type": "string",
      "minLength": 3
    },
    "pillar": {
      "type": "string",
      "minLength": 2
    },
    "weight": {
      "type": "number",
      "minimum": 0
    },
    "scope": {
      "type": "string"
    },
    "answer_type": {
      "type": "string",
      "enum": [
        "boolean",
        "count",
        "text",
        "enum",
        "numeric"
      ]
    },
    "source_method": {
      "type": "string",
      "enum": [
        "crawl",
        "gsc",
        "gbp",
        "pagespeed",
        "manual_import",
        "llm_eval"
      ]
    },
    "autonomy_level": {
      "type": "string",
      "enum": [
        "observe",
        "draft",
        "limited_execute",
        "escalate"
      ]
    },
    "risk_class": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "pass_rule": {
      "type": "object"
    },
    "evidence_required": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "is_active": {
      "type": "boolean"
    }
  },
  "additionalProperties": false
}
