{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mindware-lab.github.io/schemas/contracts/CrmPrivacyRequestReceived.v1.schema.json",
  "title": "CrmPrivacyRequestReceived.v1",
  "allOf": [
    {
      "$ref": "../crm-envelope.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "contract_name": {
          "const": "CrmPrivacyRequestReceived.v1"
        },
        "contract_version": {
          "const": "v1"
        },
        "event_name": {
          "const": "ks.crm.privacy.request.received"
        },
        "payload": {
          "type": "object",
          "required": [
            "request_type",
            "source_system",
            "batch_size",
            "records"
          ],
          "properties": {
            "request_type": {
              "type": "string",
              "enum": [
                "unsubscribe",
                "erase"
              ]
            },
            "source_system": {
              "type": "string",
              "minLength": 1
            },
            "batch_size": {
              "type": "integer",
              "minimum": 0
            },
            "records": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "email"
                ],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "requested_at": {
                    "type": "string"
                  },
                  "note": {
                    "type": "string"
                  }
                },
                "additionalProperties": true
              }
            }
          },
          "additionalProperties": true
        }
      }
    }
  ]
}
