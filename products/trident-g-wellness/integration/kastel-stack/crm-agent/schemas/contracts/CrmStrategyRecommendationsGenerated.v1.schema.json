{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mindware-lab.github.io/schemas/contracts/CrmStrategyRecommendationsGenerated.v1.schema.json",
  "title": "CrmStrategyRecommendationsGenerated.v1",
  "allOf": [
    {
      "$ref": "../crm-envelope.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "contract_name": {
          "const": "CrmStrategyRecommendationsGenerated.v1"
        },
        "contract_version": {
          "const": "v1"
        },
        "event_name": {
          "const": "ks.crm.strategy.recommendations_generated"
        },
        "payload": {
          "type": "object",
          "required": [
            "strategy_window_days",
            "recommendation_count",
            "recommendations"
          ],
          "properties": {
            "strategy_window_days": {
              "type": "integer",
              "minimum": 1
            },
            "recommendation_count": {
              "type": "integer",
              "minimum": 0
            },
            "recommendations": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "id",
                  "theme",
                  "confidence",
                  "expected_lift",
                  "risk"
                ],
                "properties": {
                  "id": {
                    "type": "string",
                    "minLength": 1
                  },
                  "theme": {
                    "type": "string",
                    "minLength": 1
                  },
                  "confidence": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                  },
                  "expected_lift": {
                    "type": "object",
                    "required": [
                      "metric",
                      "relative_lift"
                    ],
                    "properties": {
                      "metric": {
                        "type": "string",
                        "minLength": 1
                      },
                      "relative_lift": {
                        "type": "number"
                      },
                      "expected_delta": {
                        "type": "number"
                      }
                    },
                    "additionalProperties": true
                  },
                  "risk": {
                    "type": "object",
                    "required": [
                      "level",
                      "rationale"
                    ],
                    "properties": {
                      "level": {
                        "type": "string",
                        "enum": [
                          "low",
                          "medium",
                          "high"
                        ]
                      },
                      "rationale": {
                        "type": "string",
                        "minLength": 1
                      }
                    },
                    "additionalProperties": true
                  }
                },
                "additionalProperties": true
              }
            }
          },
          "additionalProperties": true
        }
      }
    }
  ]
}
