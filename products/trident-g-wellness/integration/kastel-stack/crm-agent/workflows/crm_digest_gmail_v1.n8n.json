      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [680, 260]
    },
    {
      "parameters": {
        "jsCode": "const summary = $json || {};\nreturn [{json:{\n  subject: `CRM Weekly Digest - Run ${summary.run_id || ''}`,\n  body: `Profiles: ${summary.profile_count || 0} | Eligible: ${summary.eligible_count || 0} | Open conflicts: ${summary.conflict_open || 0}`,\n  workspace_id: summary.workspace_id || $env.WORKSPACE_ID || 'wellness_sa',\n  mission_id: summary.mission_id || '',\n  run_id: summary.run_id || '',\n  event_name: 'ks.observe.metrics_recorded',\n  contract_name: 'CrmDeliverabilityAlertRaised.v1',\n  contract_version: 'v1',\n  event_id: summary.run_id || '',\n  idempotency_key: `crm-digest-${summary.run_id || 'pending'}`,\n  risk_level: 'low',\n  psi_state: 'map',\n  producer_domain: 'n8n.crm.digest',\n  consumer_domain: 'kernel.crm.digest',\n  occurred_at: $now.toISO(),\n  trace_refs: ['n8n:crm_digest_gmail_v1'],\n  payload: {\n    alert_type: 'weekly_digest',\n    severity: 'info',\n    message: 'weekly crm digest prepared'\n  }\n}}];"
      },
      "id": "n4",
      "name": "Build Digest",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [930, 260]
    },
    {
      "parameters": {
        "mode": "raw",
        "jsonOutput": "={\"note\":\"Attach to Gmail node\",\"to\":$env.GMAIL_TO,\"subject\":$json.subject,\"body\":$json.body}"
      },
      "id": "n5",
      "name": "Gmail Adapter Note",
