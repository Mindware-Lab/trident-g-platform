        "jsonBody": "={\n  \"workspace_id\": $json.workspace_id,\n  \"mission_id\": $json.mission_id,\n  \"run_id\": $json.run_id,\n  \"contract_name\": \"CrmStrategyIntentProposed.v1\",\n  \"contract_version\": \"v1\",\n  \"event_name\": \"ks.intent.created\",\n  \"event_id\": $json.run_id,\n  \"idempotency_key\": \"crm-strategy-intent-\" + $json.run_id,\n  \"risk_level\": \"medium\",\n  \"psi_state\": \"commit\",\n  \"producer_domain\": \"n8n.crm.strategy\",\n  \"consumer_domain\": \"kernel.crm.intent\",\n  \"occurred_at\": $now.toISO(),\n  \"trace_refs\": [\"n8n:crm_strategy_intel_v1\"],\n  \"payload\": {\n    \"intent_type\": $json.intent_type || \"draft_strategy_message_offer\",\n    \"strategy_theme\": $json.strategy_theme || \"segment_message_offer_pricing\",\n    \"target_segments\": $json.target_segments || [\"high_value_spend\", \"lapsed_paid\"],\n    \"recommendation_ids\": $json.recommendation_ids || []\n  }\n}"
      },
      "id": "n4",
      "name": "Propose Strategy Intents",
      "type": "n8n-nodes-base.httpRequest",
