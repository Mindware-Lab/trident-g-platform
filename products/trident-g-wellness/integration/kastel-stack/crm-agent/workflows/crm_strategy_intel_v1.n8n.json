            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"workspace_id\": $json.workspace_id,\n  \"mission_id\": $json.mission_id,\n  \"run_id\": $json.run_id,\n  \"contract_name\": \"CrmStrategyIntentProposed.v1\",\n  \"contract_version\": \"v1\",\n  \"event_name\": \"ks.intent.created\",\n  \"event_id\": $json.run_id,\n  \"idempotency_key\": \"crm-strategy-gate-\" + $json.run_id,\n  \"risk_level\": \"medium\",\n  \"psi_state\": \"commit\",\n  \"producer_domain\": \"n8n.crm.strategy\",\n  \"consumer_domain\": \"kernel.crm.intent_gate\",\n  \"occurred_at\": $now.toISO(),\n  \"trace_refs\": [\"n8n:crm_strategy_intel_v1\"],\n  \"payload\": {\n    \"intent_type\": $json.intent_type || \"draft_strategy_message_offer\",\n    \"allow_auto\": [],\n    \"force_draft\": [\"draft_strategy_message_offer\", \"draft_strategy_pricing_experiment\", \"draft_strategy_promotion_plan\", \"draft_strategy_conversion_pipeline\"],\n    \"force_escalate\": [\"apply_live_price_change\", \"launch_unreviewed_promotion\", \"consent_override\", \"suppression_override\"]\n  }\n}"
