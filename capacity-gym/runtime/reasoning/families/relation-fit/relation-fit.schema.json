{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Relation Fit Item Schema",
  "type": "object",
  "required": [
    "id",
    "family",
    "subtype",
    "wrapper_type",
    "difficulty_tier",
    "binding_load",
    "uncertainty_level",
    "control_burden",
    "logical_form",
    "premises",
    "query",
    "answer_type",
    "options",
    "correct_answer"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "family": {
      "const": "relation_fit"
    },
    "subtype": {
      "type": "string",
      "enum": [
        "same_relation",
        "resolve_slots",
        "consistent_with_facts",
        "same_relation_mcq",
        "select_all_valid",
        "relation_satisfaction",
        "multi_relation_validation"
      ]
    },
    "semantic_v2": {
      "type": "boolean"
    },
    "prompt_type": {
      "type": "string",
      "enum": [
        "same_relation_single",
        "same_relation_multi",
        "choose_x",
        "choose_y",
        "choose_z",
        "choose_assignment",
        "choose_not_enough_information"
      ]
    },
    "wrapper_type": {
      "type": "string",
      "enum": [
        "real_world",
        "nonsense"
      ]
    },
    "difficulty_tier": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "binding_load": {
      "type": "integer",
      "minimum": 1,
      "maximum": 4
    },
    "uncertainty_level": {
      "type": "integer",
      "minimum": 1,
      "maximum": 4
    },
    "control_burden": {
      "type": "integer",
      "minimum": 1,
      "maximum": 4
    },
    "logical_form": {
      "type": "string"
    },
    "target_relation_type": {
      "type": "string"
    },
    "target_semantic": {
      "$ref": "#/$defs/semanticStatement"
    },
    "premise_semantics": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/semanticStatement"
      }
    },
    "pre_flight_check": {
      "type": [
        "object",
        "null"
      ],
      "properties": {
        "unique_solution": {
          "type": "boolean"
        },
        "solution_count": {
          "type": "integer"
        },
        "solution": {
          "type": [
            "object",
            "null"
          ]
        }
      }
    },
    "premises": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "query": {
      "type": "string"
    },
    "answer_type": {
      "type": "string",
      "enum": [
        "single_choice",
        "multi_select",
        "true_false"
      ]
    },
    "options": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "text"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "semantic_label": {
            "type": "string",
            "enum": [
              "equivalent",
              "contradiction",
              "consistent",
              "forced",
              "irrelevant"
            ]
          },
          "semantic": {
            "$ref": "#/$defs/semanticStatement"
          },
          "explanation": {
            "type": "string"
          }
        }
      }
    },
    "correct_answer": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "explanation": {
      "type": "string"
    },
    "skill_tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "semanticStatement": {
      "type": "object",
      "properties": {
        "relation": {
          "type": "string"
        },
        "lhs": {
          "type": "string"
        },
        "rhs": {
          "type": "string"
        },
        "polarity": {
          "type": "string"
        }
      }
    }
  }
}
